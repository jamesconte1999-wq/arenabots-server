# Copy to .env for local dev
PORT=2567
JWT_SECRET=change-this-in-production-please-use-a-long-random-string
DB_FILE=./arenabots.db
ALLOWED_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# ----------------------------------------------------------------------------
# Stripe (real payments). LEAVE EMPTY to keep the demo (free) flow active.
# Setup steps in PAYMENTS.md
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Where Stripe Checkout redirects after success/cancel (must be https in prod):
PUBLIC_BASE_URL=http://localhost:8765

# Stripe Price IDs — create products+prices in Stripe Dashboard, then paste here.
# Crown packs (one-time payments). Map matches js/store.js CROWN_PACKS keys.
STRIPE_PRICE_CROWNS_STARTER=
STRIPE_PRICE_CROWNS_PLUS=
STRIPE_PRICE_CROWNS_PRO=
STRIPE_PRICE_CROWNS_ELITE=
# Pro Pass (subscription for monthly/yearly, one-time for lifetime).
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PRO_LIFETIME=
